# Environment Variables Template
# Copy this to .env.local and add your actual API keys

# Choose ONE provider (the one you have an API key for):

# Option 1: Anthropic Claude (Recommended for quality)
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Option 2: Google Gemini (Free tier available, fastest)
# GEMINI_API_KEY=your-actual-gemini-key-here

# Option 3: OpenAI GPT-4 (Premium option)
# OPENAI_API_KEY=sk-your-actual-openai-key-here

# Node Environment
NODE_ENV=production
